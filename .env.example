# Copy to .env in this package root.
#
# Default `pnpm test` = unit tests only. Remote check: `pnpm test:live` (needs MAIL_HOST, MAIL_FROM, MAIL_TO).
#
# --- TLS verification (no MAIL_TLS_INSECURE) ---
# If verify fails, the problem is usually not this library:
# - Server must send the full chain (leaf + intermediate CAs).
# - Private / org CA (e.g. only in /etc/ssl/certs/): Node does not load every OS PEM by default.
#   Use SMTP_TLS_CA=/etc/ssl/certs/your-ca.pem (preferred) or SMTP_TLS_CERT for the same, or NODE_EXTRA_CA_CERTS.
# - Wrong SNI: if MAIL_HOST is an IP, or the TCP name does not match the cert, set
#   MAIL_TLS_SERVERNAME to the hostname on the certificate (e.g. mail.example.com).
# MAIL_TLS_INSECURE=1 turns verification off — only for local/debug, not “proper” TLS.

# MAIL_HOST = remote SMTP server to connect to. Not your EHLO name.
MAIL_HOST=smtp.example.com
MAIL_FROM=you@example.com
MAIL_TO=recipient@example.com
# MAIL_EHLO_HOST = optional EHLO name (defaults to the domain of MAIL_FROM for SPF alignment, else OS hostname).
# MAIL_PORT=587
# MAIL_STARTTLS=1
# MAIL_SECURE=1
# MAIL_TLS_SERVERNAME=mail.example.com
# SMTP_TLS_CA=/etc/ssl/certs/trader-internet-ca.pem
# SMTP_TLS_CERT=/path/to/ca-or-chain.pem

# Optional: override smtp-server’s bundled cert for the negotiateTLS unit test (same SMTPServer as other tests).
# SMTP_TLS_CERT=/path/to/server.crt
# SMTP_TLS_KEY=/path/to/server.key
