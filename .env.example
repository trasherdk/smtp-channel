# `pnpm test` = offline. `pnpm test:live` uses MAIL_* below when you copy to .env.
MAIL_FROM=you@yourdomain.com
MAIL_TO=you@yourdomain.com
MAIL_HOST=smtp.yourdomain.com
# MAIL_TO_MX=you@example.com

# SMTP_TLS_CA=/path/to/ca.pem   # optional; merged with default roots for live tests

# Optional: negotiateTLS unit test (`tests/index.test.ts`).
# SMTP_TLS_CERT=/path/to/server.crt
# SMTP_TLS_KEY=/path/to/server.key
